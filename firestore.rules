rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isTreasurer() {
      return signedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == "treasurer";
    }

    function isAssistant() {
      return signedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == "assistant";
    }

    match /usuarios/{userId} {
      allow read: if isTreasurer() || (signedIn() && request.auth.uid == userId);
      allow write: if isTreasurer();
    }

    match /adiantamentos/{advanceId} {
      allow read, create, update, delete: if isTreasurer();
    }

    match /autorizacoes_repasse/{authorizationId} {
      allow read: if isTreasurer() || isAssistant();
      allow create: if isTreasurer();
      allow update: if isTreasurer() || isAssistant();
    }

    match /historico_eventos/{historyId} {
      allow read: if isTreasurer() || isAssistant();
      allow create: if isTreasurer() || isAssistant();
      allow update, delete: if false;
    }

    match /pastas_arquivos/{folderId} {
      allow read, create, update, delete: if isTreasurer();
    }

    match /sessoes_upload_drive/{sessionId} {
      allow read, create, update, delete: if isTreasurer();

      match /controle/{docId} {
        allow read, write: if isTreasurer();
      }
    }

    match /arquivos/{fileId} {
      allow read, create, update, delete: if isTreasurer();
    }

    match /acesso_auxiliar/{token} {
      allow read, create, update, delete: if isTreasurer();

      match /ordens/{orderId} {
        allow read, create, update, delete: if isTreasurer();
      }
    }
  }
}
